---
import { chartIds } from '../lib/ui/chartContract';

interface Props {
  index: any; 
  translations: any;
}
const { index, translations } = Astro.props;
---
<div class="panel-wrapper">
  <div id={chartIds.descriptorPanel} class="panel empty" 
    data-index={JSON.stringify(index)} 
    data-translations={JSON.stringify(translations)}
    aria-live="polite"
    aria-atomic="true"
  >
    <div class="panel-empty-state">
      <p>{translations.empty}</p>
    </div>
    
    <div class="panel-content hidden">
      <div class="panel-header">
        <h2 id={chartIds.panelTitle}>{translations.select}</h2>
        <span id={chartIds.panelPolarity} class="badge"></span>
      </div>
      <div class="panel-body">
        <div id={chartIds.panelMeta} class="meta-box" hidden></div>
      </div>
    </div>
  </div>
</div>

<style>
  .panel-wrapper {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hidden { display: none !important; }
  .panel {
    padding: 1.5rem;
    background: var(--panel-bg);
    backdrop-filter: blur(8px);
    box-shadow: var(--panel-shadow);
    border-radius: 12px;
    border: 1px solid var(--panel-border);
    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .panel {
      transition: none;
    }
  }
  .panel.empty {
    background: var(--bg);
    border: 1px dashed var(--panel-border);
    box-shadow: none;
    text-align: center;
    color: var(--text-muted);
  }
  .panel-empty-state {
    padding: 1rem 0;
  }
  .panel-empty-state p {
    margin: 0;
    font-size: 1rem;
  }
  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--header-border);
  }
  .panel-header h2 { 
    margin: 0; 
    font-size: 1.25rem; 
    color: var(--heading);
  }
  .badge {
    padding: 0.25rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge.positive { background: #dcfce7; color: #166534; }
  .badge.defect { background: #fee2e2; color: #991b1b; }
  .badge.contextual { background: #fef9c3; color: #854d0e; }
  
  .meta-box {
    background: var(--meta-bg);
    padding: 0.65rem 0.85rem;
    border-radius: 6px;
    color: var(--text);
  }
  .meta-box p {
    margin: 0;
  }
  .meta-box p + p {
    margin-top: 0.85rem;
  }
  .meta-box .meta-notes,
  .meta-box .meta-aliases {
    font-size: 0.95rem;
    line-height: 1.5;
  }
</style>
