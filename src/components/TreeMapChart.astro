---
interface Props {
  data: any;
}
const { data } = Astro.props;
---
<div id="tree-chart" class="chart-container" style="min-height: 750px; width: 100%; position: relative;">
  <div class="chart-watermark">
    <a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener">CC BY-NC 4.0</a>
  </div>
</div>
<script is:inline type="application/json" id="tree-data" set:html={JSON.stringify(data)} />

<style>
  .chart-container {
    --tree-chart-height-scale: 1.25;
    --tree-chart-desktop-min-height: 850px;
    --tree-chart-mobile-min-height: 700px;
    width: 100%;
    flex: 1;
    min-height: calc(var(--tree-chart-desktop-min-height) * var(--tree-chart-height-scale));
  }
  @media (max-width: 900px) {
    .chart-container {
      height: 100%;
      min-height: calc(var(--tree-chart-mobile-min-height) * var(--tree-chart-height-scale));
    }
  }

  .chart-watermark {
    position: absolute;
    bottom: 20px;
    right: 20px;
    z-index: 10;
    pointer-events: auto;
    background: var(--panel-bg);
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-family: sans-serif;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    user-select: none;
    border: 1px solid var(--panel-border);
    transition: opacity 0.3s;
  }
  .chart-watermark:hover {
    opacity: 1;
    background: var(--meta-bg);
  }
  .chart-watermark a {
    color: inherit;
    text-decoration: none;
  }
</style>

<script>
  import { initEcharts } from '../lib/charts/echartsRuntime';
  import {
    bindNodeSelection,
    bindResize,
    buildStyleFilteredTree,
    emitChartRootState,
    getInitialTheme,
    stripItemStyles
  } from '../lib/charts/mateWheelChart';

  const container = document.getElementById('tree-chart');
  const dataElement = document.getElementById('tree-data');

  if (container && dataElement) {
    const chartData = JSON.parse(dataElement.textContent || '{}');
    const isMobileViewport = () => window.matchMedia('(max-width: 900px)').matches;
    const colorMap: Record<string, string> = {};

    const buildColorMap = (node: any, inheritedColor?: string) => {
      const color = node.itemStyle?.color || inheritedColor;
      if (color) {
        colorMap[node.id] = color;
      }
      if (node.children) {
        node.children.forEach((child: any) => buildColorMap(child, color));
      }
    };

    chartData.children.forEach((child: any) => buildColorMap(child));

    const cleanData = {
      name: 'Mate',
      children: stripItemStyles(chartData.children || [])
    };

    let activeStyleId: string | undefined;
    const collapsedNodeIds = new Set<string>();
    let chart = initEcharts(container, getInitialTheme() === 'dark' ? 'dark' : undefined);

    const applyCollapsedState = (nodes: any[]): any[] =>
      nodes.map((node) => {
        const nextNode = {
          ...node
        };

        if (node.children) {
          nextNode.children = applyCollapsedState(node.children);
          nextNode.collapsed = collapsedNodeIds.has(node.id);
        }

        return nextNode;
      });

    const getDisplayedTreeData = () => {
      const styledChildren = buildStyleFilteredTree(cleanData.children || [], activeStyleId, 0.15);
      return {
        ...cleanData,
        children: applyCollapsedState(styledChildren)
      };
    };

    const emitRootState = () => {
      emitChartRootState('treemap', collapsedNodeIds.size === 0);
    };

    const getOption = (theme: 'dark' | 'light') => ({
      backgroundColor: 'transparent',
      tooltip: {
        trigger: 'item',
        formatter: '{b}'
      },
      series: {
        type: 'tree',
        data: [getDisplayedTreeData()],
        layout: 'orthogonal',
        orient: 'LR',
        symbol: 'circle',
        symbolSize: 8,
        initialTreeDepth: -1,
        left: '10%',
        right: '18%',
        top: '5%',
        bottom: '5%',
        animationDurationUpdate: 750,
        emphasis: {
          focus: 'ancestor'
        },
        label: {
          position: 'left',
          verticalAlign: 'middle',
          align: 'right',
          fontSize: 10,
          color: theme === 'dark' ? '#cbd5e1' : '#334155'
        },
        leaves: {
          label: {
            position: 'right',
            verticalAlign: 'middle',
            align: 'left',
            fontSize: 10,
            color: theme === 'dark' ? '#94a3b8' : '#64748b'
          }
        },
        itemStyle: {
          color: (params: any) => colorMap[params.data?.id] || '#999',
          borderWidth: 0
        },
        lineStyle: {
          width: 1.5,
          curveness: 0.5,
          color: theme === 'dark' ? '#475569' : '#cbd5e1'
        },
        expandAndCollapse: true,
        roam: !isMobileViewport()
      }
    });

    const bindRootTracking = () => {
      chart.on('click', (params: any) => {
        if (params?.seriesType !== 'tree' || !params.data?.id || !params.data.children?.length) {
          return;
        }

        if (collapsedNodeIds.has(params.data.id)) {
          collapsedNodeIds.delete(params.data.id);
        } else {
          collapsedNodeIds.add(params.data.id);
        }

        emitRootState();
      });
    };

    const renderChart = (theme: 'dark' | 'light') => {
      chart.dispose();
      chart = initEcharts(container, theme === 'dark' ? 'dark' : undefined);
      chart.setOption(getOption(theme));
      bindNodeSelection(chart);
      bindRootTracking();
      emitRootState();
    };

    chart.setOption(getOption(getInitialTheme()));
    bindNodeSelection(chart);
    bindRootTracking();
    emitRootState();

    bindResize(() => chart, container);

    window.addEventListener('style-filter-changed', ((event: CustomEvent) => {
      activeStyleId = event.detail.styleId;
      chart.setOption({
        series: {
          data: [getDisplayedTreeData()]
        }
      });
    }) as EventListener);

    window.addEventListener('chart-reset-to-root-requested', ((event: CustomEvent<{ type: string }>) => {
      if (event.detail.type === 'treemap') {
        collapsedNodeIds.clear();
        renderChart(getInitialTheme());
      }
    }) as EventListener);

    window.addEventListener('theme-changed', (event: any) => {
      renderChart(event.detail.theme);
    });

    window.addEventListener('chart-type-changed', () => {
      setTimeout(() => chart.resize(), 50);
    });
  }
</script>
