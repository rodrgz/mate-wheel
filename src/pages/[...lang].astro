---
import { render } from 'astro:content';
import { loadNormalizedWheel, loadReferenceEntry, resolveLocale } from '../lib/content/mateWheel';
import { panelCopy, siteCopy } from '../lib/i18n/siteCopy';
import PageHeader from '../components/PageHeader.astro';
import ChartModeToggle from '../components/ChartModeToggle.astro';
import ProjectAbout from '../components/ProjectAbout.astro';
import ProjectFooter from '../components/ProjectFooter.astro';
import SunburstChart from '../components/SunburstChart.astro';
import TreeMapChart from '../components/TreeMapChart.astro';
import DescriptorPanel from '../components/DescriptorPanel.astro';
import '../styles/global.css';

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } }, // pt (default)
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const { lang } = Astro.params;
const locale = resolveLocale(lang);

const normalized = await loadNormalizedWheel(locale);
const referenceEntry = await loadReferenceEntry(locale);
const { Content } = await render(referenceEntry);
const translations = siteCopy[locale];
const panelTranslations = panelCopy[locale];
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:;" />
    <meta name="viewport" content="width=device-width" />
    <title>{translations.title}</title>
    <style>
      .lang-switcher {
        display: flex;
        gap: 0.5rem;
        margin-right: 1rem;
        font-size: 0.85rem;
        font-weight: 600;
      }
      .lang-switcher a {
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        text-decoration: none;
        color: #64748b;
        transition: all 0.2s;
      }
      .lang-switcher a:hover {
        background: var(--meta-bg);
        color: var(--heading);
      }
      .lang-switcher a.active {
        background: var(--primary);
        color: white;
      }
      .reference-section {
        margin-top: 4rem;
        padding-top: 4rem;
        border-top: 1px solid var(--header-border);
        scroll-margin-top: 2rem;
      }
      .styles-block {
        margin: 3rem 0;
        padding: 2rem;
        background: var(--meta-bg);
        border: 1px solid var(--header-border);
        border-radius: 8px;
      }
      .style-item { margin-bottom: 1.5rem; }
      .style-item h3 { margin: 0 0 0.5rem 0; color: var(--heading); }
      .style-item p { margin: 0; color: var(--text); }

      .about-section {
        margin: 2rem 0;
        padding: 2rem;
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid var(--primary);
        border-radius: 12px;
        color: var(--text);
      }
      .about-section h3 {
        margin: 0 0 1rem 0;
        color: var(--primary);
        font-size: 1.25rem;
      }
      .about-section p {
        margin: 0;
        line-height: 1.6;
        font-size: 1.05rem;
      }
      .about-section a {
        color: #059669;
        font-weight: 600;
        text-decoration: underline;
      }

      /* Markdown content basic styling */
      .reference-content {
        min-width: 0;
      }

      .reference-content :global(.reference-table-scroll) {
        margin: 1.5rem 0;
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        overscroll-behavior-x: contain;
        -webkit-overflow-scrolling: touch;
      }

      .reference-content :global(h1), 
      .reference-content :global(h2), 
      .reference-content :global(h3) {
        color: var(--heading);
        margin-top: 2rem;
      }
      .reference-content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        table-layout: auto;
      }

      .reference-content :global(.reference-table-scroll table) {
        margin: 0;
      }

      .reference-content :global(th), 
      .reference-content :global(td) {
        padding: 0.75rem;
        border: 1px solid var(--header-border);
        text-align: left;
        white-space: normal;
        word-break: normal;
        overflow-wrap: normal;
        -webkit-hyphens: auto;
        hyphens: auto;
      }
      .reference-content :global(th) {
        background: var(--meta-bg);
      }

      @media (max-width: 900px) {
        .reference-content :global(.reference-table-scroll) {
          margin: 1.25rem 0;
        }

        .reference-content :global(.reference-table-scroll table) {
          width: var(--reference-table-mobile-width);
          min-width: var(--reference-table-mobile-width);
        }

        .reference-content :global(th),
        .reference-content :global(td) {
          padding: 0.625rem;
        }
      }

      /* Accessibility & Quality Improvements */
      :focus-visible { 
        outline: 3px solid #10b981; 
        outline-offset: 2px; 
      }
      
      .skip-link {
        position: absolute;
        top: -100px;
        left: 0;
        background: #10b981;
        color: white;
        padding: 1rem;
        z-index: 9999;
        transition: top 0.2s;
        text-decoration: none;
        font-weight: bold;
      }
      
      .skip-link:focus-visible {
        top: 0;
      }

      a, button {
        touch-action: manipulation;
      }

      .app-footer {
        margin-top: 4rem;
        padding: 4rem 1rem;
        border-top: 1px solid var(--header-border);
        text-align: center;
        color: var(--text-muted);
        font-size: 0.875rem;
      }
      .footer-license {
        margin-top: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: center;
      }
      .footer-license a {
        color: var(--primary);
        text-decoration: underline;
        font-weight: 500;
      }
      .footer-license p {
        margin: 0;
        max-width: 600px;
        line-height: 1.5;
      }

      .theme-toggle,
      .github-link {
        transition: all 0.2s;
        text-decoration: none;
      }

      .theme-toggle:hover, .github-link:hover, .chart-toggle:hover {
        background: var(--meta-bg);
        border-color: var(--primary);
        color: var(--primary);
      }

      .chart-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid var(--header-border);
        background: var(--header-bg);
        color: var(--text);
        cursor: pointer;
        transition: all 0.2s;
      }
      .chart-toggle.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
      }

      .theme-toggle svg, .github-link svg, .chart-toggle svg {
        width: 20px;
        height: 20px;
      }

      .zoom-indicator {
        position: absolute;
        bottom: 15px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--panel-bg);
        border: 1px solid var(--panel-border);
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 6px;
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      }

      .zoom-indicator.visible {
        opacity: 1;
      }

      :root.dark .zoom-indicator {
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
      }

      @keyframes whisper {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 0.9; }
      }

      .sun-icon { display: none; }
      .moon-icon { display: block; }
      
      :root.dark .sun-icon { display: block; }
      :root.dark .moon-icon { display: none; }
    </style>
    <script is:inline>
      // Initial theme detection to prevent flash
      (function() {
        const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Pular para o conteúdo principal</a>
    <PageHeader title={translations.title} subtitle={translations.subtitle} locale={locale} />

    <main id="main-content" class="container">
      <div class="main-layout">
        <section class="wheel-section">
          <ChartModeToggle
            toggleChartLabel={translations.toggleChart}
            resetChartRootLabel={translations.resetChartRoot}
            treeZoomHint={translations.treeZoomHint}
          />
          <div class="wheel-scroll-shell">
            <div class="wheel-scroll-frame">
              <div id="chart-sunburst-wrapper">
                <SunburstChart data={normalized.sunburst} />
              </div>
              <div id="chart-treemap-wrapper" style="display: none;">
                <TreeMapChart data={normalized.sunburst} />
              </div>
            </div>
          </div>
        </section>
        <section class="panel-section">
          <DescriptorPanel
            index={normalized.descriptorIndex}
            translations={panelTranslations}
          />
        </section>
      </div>

      <ProjectAbout
        title={translations.aboutTitle}
        p1={translations.aboutP1}
        p2={translations.aboutP2}
        wheelHtml={translations.aboutWheel}
        guideHtml={translations.aboutGuide}
        p3={translations.aboutP3}
      />

      <section id="referencia" class="reference-section">
        <h2>{translations.refTitle}</h2>
        <div class="reference-content">
          <Content />
        </div>
      </section>
    </main>

    <ProjectFooter footer={translations.footer} />

    <script>
      import { setupChartToggle, setupInternalLinkScroll, setupScrollableReferenceTables, setupThemeToggle } from '../lib/ui/pageBehavior';

      setupThemeToggle();
      setupChartToggle();
      setupScrollableReferenceTables();
      setupInternalLinkScroll();
    </script>
  </body>
</html>
