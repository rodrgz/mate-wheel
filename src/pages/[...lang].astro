---
import { render } from 'astro:content';
import { loadNormalizedWheel, loadReferenceEntry, resolveLocale } from '../lib/content/mateWheel';
import { panelCopy, siteCopy, siteMeta } from '../lib/i18n/siteCopy';
import PageHeader from '../components/PageHeader.astro';
import ChartModeToggle from '../components/ChartModeToggle.astro';
import ProjectFooter from '../components/ProjectFooter.astro';
import SunburstChart from '../components/SunburstChart.astro';
import TreeMapChart from '../components/TreeMapChart.astro';
import DescriptorPanel from '../components/DescriptorPanel.astro';
import { chartIds } from '../lib/ui/chartContract';
import '../styles/global.css';

export async function getStaticPaths() {
  return [
    { params: { lang: undefined } }, // pt (default)
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const { lang } = Astro.params;
const locale = resolveLocale(lang);

const normalized = await loadNormalizedWheel(locale);
const referenceEntry = await loadReferenceEntry(locale);
const { Content } = await render(referenceEntry);
const translations = siteCopy[locale];
const panelTranslations = panelCopy[locale];
const contentSecurityPolicy = import.meta.env.DEV
  ? undefined
  : "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: blob:; connect-src 'self';";

// --- SEO helpers ---
const base = siteMeta.basePath;
const siteOrigin = siteMeta.siteUrl;

const localePaths: Record<string, string> = {
  pt: `${base}/`,
  en: `${base}/en/`,
  es: `${base}/es/`,
};

const canonicalPath = localePaths[locale];
const canonicalUrl = `${siteOrigin}${canonicalPath}`;

const ogLocaleMap: Record<string, string> = {
  pt: 'pt_BR',
  en: 'en_US',
  es: 'es_ES',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: translations.title,
  description: translations.description,
  url: canonicalUrl,
  inLanguage: locale,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Any',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: 'Erik Rodriguez',
  },
  license: 'https://creativecommons.org/licenses/by-nc/4.0/',
};
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    {contentSecurityPolicy && (
      <meta
        http-equiv="Content-Security-Policy"
        content={contentSecurityPolicy}
      />
    )}
    <meta name="viewport" content="width=device-width" />
    <title>{translations.title} — {translations.subtitle}</title>
    <meta name="description" content={translations.description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

    {/* Canonical & hreflang */}
    <link rel="canonical" href={canonicalUrl} />
    {Object.entries(localePaths).map(([loc, path]) => (
      <link rel="alternate" hreflang={loc === 'pt' ? 'pt-BR' : loc} href={`${siteOrigin}${path}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteOrigin}${localePaths.pt}`} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mate em Roda" />
    <meta property="og:title" content={`${translations.title} — ${translations.subtitle}`} />
    <meta property="og:description" content={translations.ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {Object.entries(ogLocaleMap).filter(([l]) => l !== locale).map(([, ogLoc]) => (
      <meta property="og:locale:alternate" content={ogLoc} />
    ))}

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${translations.title} — ${translations.subtitle}`} />
    <meta name="twitter:description" content={translations.ogDescription} />

    {/* Structured Data */}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline src={`${base}/theme-init.js`}></script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">{translations.skipLinkLabel}</a>
    <PageHeader
      title={translations.title}
      subtitle={translations.subtitle}
      locale={locale}
      languageSwitcherLabel={translations.languageSwitcherLabel}
      themeToggleLabel={translations.themeToggleLabel}
    />

    <main id="main-content" class="container">
      <div class="main-layout">
        <section class="wheel-section">
          <ChartModeToggle
            toggleChartLabel={translations.toggleChart}
            resetChartRootLabel={translations.resetChartRoot}
            treeZoomHint={translations.treeZoomHint}
          />
          <div class="wheel-scroll-shell">
            <div class="wheel-scroll-frame">
              <div id={chartIds.chartSunburstWrapper}>
                <SunburstChart data={normalized.sunburst} />
              </div>
              <div id={chartIds.chartTreemapWrapper} hidden></div>
            </div>
          </div>
          <TreeMapChart data={normalized.sunburst} />
        </section>
        <section class="panel-section">
          <DescriptorPanel
            index={normalized.descriptorIndex}
            translations={panelTranslations}
          />
        </section>
      </div>

      <section id="referencia" class="reference-section">
        <div class="reference-content">
          <Content />
        </div>
      </section>
    </main>

    <ProjectFooter
      footer={translations.footer}
      codeLicensedUnder={translations.codeLicensedUnder}
      contentTaxonomyLicensedUnder={translations.contentTaxonomyLicensedUnder}
      commercialUseNotice={translations.commercialUseNotice}
      contactLabel={translations.contactLabel}
      contactEmail={siteMeta.contactEmail}
      contributorsLabel={translations.contributorsLabel}
      contributors={siteMeta.contributors}
    />

    <script>
      import {
        setupChartControlsHintPeek,
        setupChartToggle,
        setupInternalLinkScroll,
        setupScrollableReferenceTables,
        setupThemeToggle,
      } from '../lib/ui/pageBehavior';
      import { setupDescriptorPanel } from '../lib/ui/descriptorPanel';

      setupThemeToggle();
      setupChartToggle();
      setupChartControlsHintPeek();
      setupDescriptorPanel();
      setupScrollableReferenceTables();
      setupInternalLinkScroll();
    </script>
  </body>
</html>
